# =============================================================================
# virt-poc-sample 환경 설정 파일
# setup.sh 실행 시 자동 생성됩니다. 직접 편집도 가능합니다.
# 이 파일을 복사하여 env.conf 로 저장 후 값을 수정하세요.
# =============================================================================

# -----------------------------------------------------------------------------
# 클러스터 기본 정보
# -----------------------------------------------------------------------------
# OpenShift 클러스터 base domain (예: example.com)
CLUSTER_DOMAIN=example.com

# OpenShift API 서버 URL (예: https://api.example.com:6443)
CLUSTER_API=https://api.example.com:6443

# -----------------------------------------------------------------------------
# 사용자 계정 (htpasswd)
# -----------------------------------------------------------------------------
# 관리자 계정
HTPASSWD_ADMIN_USER=ocpadmin
HTPASSWD_ADMIN_PASS=Admin1234!

# 일반 사용자 계정
HTPASSWD_USER=ocpuser
HTPASSWD_USER_PASS=User1234!

# -----------------------------------------------------------------------------
# 네트워크 설정 (NNCP / NAD)
# -----------------------------------------------------------------------------
# NNCP용 노드 네트워크 인터페이스 이름 (예: ens4, eth1)
BRIDGE_INTERFACE=ens4

# 생성할 Linux Bridge 이름
BRIDGE_NAME=br1

# NAD가 생성될 네임스페이스
NAD_NAMESPACE=poc-nad

# -----------------------------------------------------------------------------
# MinIO 설정 (OADP S3 backend)
# -----------------------------------------------------------------------------
# MinIO Access Key
MINIO_ACCESS_KEY=minio

# MinIO Secret Key
MINIO_SECRET_KEY=minio123

# OADP 백업에 사용할 버킷 이름
MINIO_BUCKET=velero

# MinIO 서비스 URL (MinIO 배포 후 자동 설정)
# 예: http://minio.poc-minio.svc.cluster.local:9000
MINIO_ENDPOINT=http://minio.poc-minio.svc.cluster.local:9000

# -----------------------------------------------------------------------------
# VDDK (VMware Virtual Disk Development Kit)
# -----------------------------------------------------------------------------
# 내부 이미지 레지스트리에 push된 VDDK 이미지 경로
# 예: image-registry.openshift-image-registry.svc:5000/openshift/vddk:latest
VDDK_IMAGE=image-registry.openshift-image-registry.svc:5000/openshift/vddk:latest

# -----------------------------------------------------------------------------
# Console 접근 IP 제한
# -----------------------------------------------------------------------------
# Console 접근을 허용할 CIDR 목록 (쉼표로 구분)
# 예: 10.0.0.0/8,192.168.0.0/16
CONSOLE_ALLOWED_CIDRS=0.0.0.0/0

# API 서버 접근을 허용할 CIDR 목록
API_ALLOWED_CIDRS=0.0.0.0/0

# -----------------------------------------------------------------------------
# Fence Agents Remediation (FAR)
# -----------------------------------------------------------------------------
# IPMI/BMC IP 주소
FENCE_AGENT_IP=192.168.1.100

# IPMI 사용자
FENCE_AGENT_USER=admin

# IPMI 비밀번호
FENCE_AGENT_PASS=password

# -----------------------------------------------------------------------------
# 노드 정보
# -----------------------------------------------------------------------------
# 워커 노드 이름 목록 (공백으로 구분)
WORKER_NODES="worker-0 worker-1 worker-2"

# 테스트에 사용할 노드 이름 (단일)
TEST_NODE=worker-0

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
# Grafana admin 비밀번호
GRAFANA_ADMIN_PASS=grafana123
